# Public site URL, used for generating share links, OG metadata, and canonical URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase project (wired up in Phase 2). Anon key is safe for the browser;
# never expose the service role key to client code or commit a real value here.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional — only needed to run the admin-authenticated E2E specs locally
# (e2e/helpers/admin.ts). Use a seeded admin_profiles account, never a real
# personal login.
E2E_ADMIN_EMAIL=admin@example.com
E2E_ADMIN_PASSWORD=change-me
